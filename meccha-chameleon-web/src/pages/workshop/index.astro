---
// Workshop maps list page.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { workshopMaps } from '../../data/workshop-maps.js';
import { pageSeo } from '../../seo/pages.js';
import { buildWebPageJsonLd } from '../../seo/meta.js';
import '../../styles/pages/ListPage.css';

const hasWorkshopMaps = workshopMaps.length > 0;
const seo = hasWorkshopMaps
	? pageSeo.workshopIndex
	: {
		title: 'MECCHA CHAMELEON Workshop Maps',
		description: 'No MECCHA CHAMELEON Workshop map notes have been published yet. Browse official map notes and multiplayer setup help instead.',
		keywords: 'meccha chameleon workshop, workshop maps, multiplayer setup',
	};
---

<BaseLayout
	title={seo.title}
	description={seo.description}
	keywords={seo.keywords}
	robots={hasWorkshopMaps ? 'index, follow' : 'noindex, follow'}
	jsonLd={buildWebPageJsonLd({
		name: seo.title,
		description: seo.description,
		path: '/workshop',
	})}
>
	<div class="ListPage WorkshopListPage">
		<section class="inner-hero-section">
			<div class="container">
				<div class="inner-hero-content">
					<nav class="breadcrumb" aria-label="Breadcrumb">
						<ol class="breadcrumb-list">
							<li><a href="/">Home</a></li>
							<li><span aria-current="page">Workshop Maps</span></li>
						</ol>
					</nav>
					<span class="section-label">Steam Workshop</span>
					<h1>MECCHA CHAMELEON Workshop Maps</h1>
					<p class="page-intro">{hasWorkshopMaps ? <>Steam Workshop listings with practical hosting checklists for community stages. We link to each item and focus on fair setup instead of inventing permanent “best spots.” Official-map facts are in the <a href="/wiki#wiki-maps">Wiki map notes</a>.</> : 'Workshop map notes will be listed here once they are published.'}</p>
				</div>
			</div>
		</section>

		<!-- compliance:workshop-index:start -->
		<section class="inner-content-section is-alt">
			<div class="container"><div class="inner-content-block is-wide">
				<h2>Official maps and Workshop stages serve different jobs</h2>
				<p>
					Official maps ship with the game and provide the most stable baseline for learning controls, role rules,
					and repeatable scene-reading habits. Workshop stages are community items distributed through Steam. They
					can offer new layouts and materials, but every player must have the correct item available and the host must
					verify that the stage behaves properly with the current game build. A Workshop listing is therefore not a
					promise that a map is balanced for every group or unchanged after every update.
				</p>
				<p>
					Use the <a href="/wiki#wiki-maps">official Wiki map notes</a> when you need a reference tied to the built-in
					roster. Use this hub when a group deliberately wants a community stage and accepts a short setup and private-test
					process. The guides below preserve creator attribution and link to the relevant Steam Workshop item instead of
					repackaging downloads.
				</p>
			</div></div>
		</section>

		<section class="inner-content-section">
			<div class="container"><div class="inner-content-block is-wide">
				<h2>Subscribe and load a community stage safely</h2>
				<ol class="inner-steps">
					<li><strong>Open the original listing.</strong> Follow the Steam link from the map guide and confirm the item name and creator before subscribing.</li>
					<li><strong>Subscribe before the lobby forms.</strong> Give Steam time to download the item; do not ask a full group to wait while each person searches for a similar title.</li>
					<li><strong>Restart when necessary.</strong> If the map does not appear in selection, close and reopen the game after Steam finishes the download.</li>
					<li><strong>Confirm the host can select it.</strong> The host should see the exact map in the lobby before sending final invites.</li>
					<li><strong>Run a small private test.</strong> Load the stage with one or two collaborators and walk through spawn, movement, hiding, searching, and round completion.</li>
					<li><strong>Share the source link.</strong> Keep the Workshop URL in the group chat so a missing or late player subscribes to the same item.</li>
				</ol>
				<p>
					Do not download map files from an unrelated mirror when Steam Workshop provides the item. The subscription
					workflow gives the creator attribution, item identifier, update information, and a common source for the room.
					If Steam or the game reports a mismatch, solve that mismatch before beginning a scored or competitive session.
				</p>
			</div></div>
		</section>

		<section class="inner-content-section is-alt">
			<div class="container"><div class="inner-content-block is-wide">
				<h2>Private host preflight checklist</h2>
				<table class="inner-data-table">
					<thead><tr><th>Test</th><th>What the host observes</th><th>Reason to pause public hosting</th></tr></thead>
					<tbody>
						<tr><td>Load and spawn</td><td>Every tester enters the same stage and receives a usable starting position</td><td>A player remains on a loading screen, falls, clips, or spawns outside the playable route</td></tr>
						<tr><td>Role loop</td><td>Preparation, hunt, tagging, timer, and results complete normally</td><td>The round cannot advance or finish under the selected mode</td></tr>
						<tr><td>Movement</td><td>Main rooms and connectors can be traversed without unintended traps</td><td>Normal routes strand a role or require unexplained workarounds</td></tr>
						<tr><td>Sightlines</td><td>Seekers can inspect major areas from more than one deliberate angle</td><td>A location is invisible because of broken geometry rather than camouflage</td></tr>
						<tr><td>Lighting</td><td>Players can distinguish surfaces and silhouettes using normal settings</td><td>A required area is unreadable or behaves differently for testers</td></tr>
						<tr><td>Group scale</td><td>The route still gives both roles meaningful decisions with the planned room size</td><td>The test suggests overcrowding, excessive empty search time, or unreliable spawns</td></tr>
					</tbody>
				</table>
				<p>
					This checklist records observations; it does not create a universal player-count recommendation. If a guide
					does not document verified capacity, start with a smaller private room, change one setting at a time, and let
					the host describe the test result before inviting more players.
				</p>
			</div></div>
		</section>

		<section class="inner-content-section">
			<div class="container"><div class="inner-content-block">
				<h2>How to compare the listed stages</h2>
				<p>
					Meeting Room is presented as a modern office interior, Viking Dining as a wood-and-stone dining environment,
					and Police Station as a department interior with desks, cabinets, corridors, and Xray-capable prop materials.
					Those descriptions suggest different scene-reading exercises, not a ranking. Read each detail page for its
					creator, source link, material notes, and test prompts, then choose the environment that matches the skill your
					group wants to observe.
				</p>
				<ul>
					<li>For repeated office shapes and clean furniture lines, review <a href="/workshop/meeting-room">Meeting Room</a>.</li>
					<li>For timber, stone, barrels, and warmer material families, review <a href="/workshop/viking-dining">Viking Dining</a>.</li>
					<li>For corridors, tiled surfaces, cabinets, and transparent-material checks, review <a href="/workshop/police-station">Police Station</a>.</li>
				</ul>
			</div></div>
		</section>

		<section class="inner-content-section is-alt">
			<div class="container"><div class="inner-content-block is-wide">
				<h2>Fair rules for the first hosted session</h2>
				<p>
					Tell players that the map is community-made, share the source, and explain what the private test confirmed.
					Avoid presenting an untested corner, collision edge, or loading quirk as a secret competitive tactic. For the
					first full room, keep the selected mode familiar and avoid changing timer, map, group size, and house rules
					simultaneously. After each round, ask whether a result came from readable camouflage and searching or from a
					technical problem.
				</p>
				<h3>Troubleshooting missing maps and mismatches</h3>
				<ul>
					<li><strong>Map missing from selection:</strong> confirm subscription, wait for Steam download completion, then restart the game.</li>
					<li><strong>One player cannot join:</strong> compare the exact Workshop URL and item ID, then verify the player's download state.</li>
					<li><strong>Different behavior between players:</strong> record game version, map update date, mode, and the step that produced the difference.</li>
					<li><strong>Round does not finish:</strong> stop the session, reproduce with fewer players, and return to an official map if the loop remains unreliable.</li>
					<li><strong>Balance feels unclear:</strong> do not publish a permanent verdict after one round; repeat the same setup and change only group size or one room setting.</li>
				</ul>
				<h3>Workshop hosting FAQ</h3>
				<p><strong>Does every player need the map?</strong> Plan the room as if every participant must subscribe to the same Steam Workshop item before joining.</p>
				<p><strong>Is a Workshop stage an official map?</strong> No. Community stages remain separate from the built-in map notes even when the game officially supports Workshop tools.</p>
				<p><strong>Can this hub guarantee a fair player count?</strong> No. Use the private test checklist and document what your current group and build actually show.</p>
			</div></div>
		</section>
		<!-- compliance:workshop-index:end -->
		<!-- Affiliate ad disabled for now; keep this block for future reuse.
		<aside class="affiliate-ad-slot" data-affiliate-ad="native" aria-label="Advertisement">
			<span class="affiliate-ad-slot__label">Advertisement</span>
			<div class="affiliate-ad-slot__frame" data-affiliate-ad-frame></div>
		</aside>
		-->
		<div data-gpt-banner-anchor></div>

		<section class="list-section" aria-labelledby="workshop-list-title">
			<div class="container">
				<div class="list-content">
					<header class="list-section-header">
						<h2 id="workshop-list-title">Community Workshop stages</h2>
					</header>
					{
						hasWorkshopMaps ? (
							<div class="workshop-list">
								{workshopMaps.map((item) => (
									<a class="workshop-row" href={`/workshop/${item.addressBar}`}>
										<div class="workshop-row__media">
											<img
												class="workshop-row__image"
												src={item.imageUrl}
												alt={item.imageAlt}
												width="800"
												height="500"
												loading="lazy"
											/>
										</div>
										<div class="workshop-row__body">
											<time class="workshop-row__meta" datetime={item.publishDate}>{item.publishDate}</time>
											<h3 class="workshop-row__title">{item.title}</h3>
											<p class="workshop-row__desc">{item.description}</p>
											<div class="workshop-row__tags">
												{item.tag.map((label) => (
													<span class="workshop-row__tag">{label}</span>
												))}
											</div>
										</div>
										<span class="workshop-row__arrow" aria-hidden="true">→</span>
									</a>
								))}
							</div>
						) : (
							<p class="list-empty-message">Sorry, there are no Workshop maps available yet.</p>
						)
					}
				</div>
			</div>
		</section>
		<!-- Affiliate ad disabled for now; keep this block for future reuse.
		<aside class="affiliate-ad-slot" data-affiliate-ad="banner" aria-label="Advertisement">
			<span class="affiliate-ad-slot__label">Advertisement</span>
			<div class="affiliate-ad-slot__frame" data-affiliate-ad-frame></div>
		</aside>
		-->
		<div data-gpt-banner-anchor></div>
	</div>
</BaseLayout>
