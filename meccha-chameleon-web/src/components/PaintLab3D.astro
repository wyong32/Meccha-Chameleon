		figurePoseSelect.addEventListener('change', () => { loadFigurePose(figurePoseSelect.value as FigurePose); updateFinish(); setStatus(`${figurePoseSelect.selectedOptions[0]?.textContent ?? 'Figure'} pose loaded`); });
		lab.querySelectorAll<HTMLButtonElement>('[data-mode]').forEach((button) => button.addEventListener('click', () => { mode = button.dataset.mode as 'paint' | 'rotate'; lab.querySelectorAll('[data-mode]').forEach((item) => { const active = item === button; item.classList.toggle('is-active', active); item.setAttribute('aria-pressed', String(active)); }); syncViewportCursorMode(); help.textContent = mode === 'paint' ? 'Paint mode: drag across the figure to apply colour to its surface.' : 'Rotate mode: drag the figure to inspect its silhouette, then switch back to paint.'; setStatus(mode === 'paint' ? 'Paint mode' : 'Rotate mode'); }));
		backgroundScaleInput.addEventListener('input', () => { if (!background) return; const scale = Number(backgroundScaleInput.value) / 100; background.scale.set(scale, scale, 1); backgroundScaleOutput.value = `${backgroundScaleInput.value}%`; setStatus(`Scene scale ${backgroundScaleInput.value}%`); requestRender(); });
		backgroundMoveButton.addEventListener('click', () => { if (!background) return; setEyedropper(false); movingBackground = !movingBackground; syncViewportCursorMode(); backgroundMoveButton.classList.toggle('is-active', movingBackground); backgroundMoveButton.setAttribute('aria-pressed', String(movingBackground)); backgroundMoveButton.textContent = movingBackground ? 'Finish positioning' : 'Position scene'; setStatus(movingBackground ? 'Drag the scene behind the figure' : 'Scene positioned'); });
		eyedropperButton.addEventListener('click', () => { if (!background) return; if (movingBackground) backgroundMoveButton.click(); const active = !pickingBackground; setEyedropper(active); help.textContent = active ? 'Eyedropper: click a colour in your uploaded scene to copy it into the palette.' : 'Paint mode: drag across the figure to apply colour to its surface.'; setStatus(active ? 'Eyedropper ready — click the uploaded scene' : 'Paint mode'); });
		fitBackgroundButton.addEventListener('click', () => { fitBackground(); setStatus('Scene fitted to canvas'); });
		clearSceneButton.addEventListener('click', () => { clearBackground(); setStatus('Scene cleared'); });
		lab.querySelector<HTMLButtonElement>('[data-reset]')!.addEventListener('click', () => { resetPaint(); setStatus('Paint reset'); });
		undoButton.addEventListener('click', () => {
			const previousState = history.pop();
			if (!previousState) return;
			previousState.forEach((imageData, index) => {
				const part = parts[index];
				(part.userData.context as CanvasRenderingContext2D).putImageData(imageData, 0, 0);
				(part.userData.texture as THREE_NS.CanvasTexture).needsUpdate = true;
			});
			undoButton.disabled = history.length === 0;
			requestRender();
			setStatus('Stroke undone');
		});
		lab.querySelector<HTMLButtonElement>('[data-save]')!.addEventListener('click', () => { requestRender(); window.requestAnimationFrame(() => { const link = document.createElement('a'); link.download = 'meccha-chameleon-camouflage-practice.png'; link.href = renderer.domElement.toDataURL('image/png'); link.click(); setStatus('PNG saved'); }); });
		presetBackgroundButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const url = button.dataset.presetBackground;
				if (!url) return;
				loadSceneTexture(url, button.dataset.sceneLabel || 'Preset scene', button);
			});
		});
		lab.querySelector<HTMLInputElement>('[data-background]')!.addEventListener('change', (event: Event) => {
			const file = (event.currentTarget as HTMLInputElement).files?.[0];
			if (!file) return;
			if (file.size > 12 * 1024 * 1024) { setStatus('Choose an image smaller than 12 MB'); return; }
			const url = URL.createObjectURL(file);
			loadSceneTexture(url, file.name, uploadSceneCard, true);
		});

		drawWheel(); sync(paintColor); loadFigurePose(figurePoseSelect.value as FigurePose); updateFinish(); resize(); loadSceneTexture('/images/simulator/simulator-bg-01.png', 'Preset 01', presetBackgroundButtons[0]); syncViewportCursorMode(); viewport.setAttribute('aria-busy', 'false'); loading.remove(); setStatus('Paint mode');
	};

	document.querySelectorAll<HTMLElement>('[data-paint-lab-3d]').forEach((lab) => {
		if ('IntersectionObserver' in window) {
			const observer = new IntersectionObserver((entries) => { if (!entries.some((entry) => entry.isIntersecting)) return; observer.disconnect(); void bootPaintLab(lab); }, { rootMargin: '160px' });
			observer.observe(lab);
			return;
		}
		void bootPaintLab(lab);
	});
</script>
